<?xml version="1.0" encoding="utf-8"?>
<AssetPackage Version="0.1.10">
	<ItemSettings>
		<ContentType>MISC</ContentType>
		<Title>VoiceWalker Toolbar Overlay</Title>
		<Manufacturer/>
		<Creator>G-Simulations</Creator>
	</ItemSettings>
	<Flags>
		<VisibleInStore>false</VisibleInStore>
		<CanBeReferenced>true</CanBeReferenced>
	</Flags>
	<PackageOrderHint>MISC</PackageOrderHint>
	<AssetGroups>
		<AssetGroup Name="ContentInfo">
			<Type Version="0">ContentInfo</Type>
			<Flags>
				<FSXCompatibility>false</FSXCompatibility>
			</Flags>
			<AssetDir>PackageDefinitions\gsimulation-voicewalker\ContentInfo</AssetDir>
			<OutputDir>ContentInfo\gsimulation-voicewalker</OutputDir>
		</AssetGroup>

		<AssetGroup Name="ingamepanel_icons">
			<Type Version="0">Copy</Type>
			<Flags>
				<FSXCompatibility>false</FSXCompatibility>
			</Flags>
			<AssetDir>PackageSources\html_ui\icons\</AssetDir>
			<OutputDir>.\html_ui\icons\</OutputDir>
		</AssetGroup>

		<AssetGroup Name="ingamepanel_html">
			<Type Version="0">Copy</Type>
			<Flags>
				<FSXCompatibility>false</FSXCompatibility>
			</Flags>
			<AssetDir>PackageSources\html_ui\InGamePanels\</AssetDir>
			<OutputDir>.\html_ui\InGamePanels\</OutputDir>
		</AssetGroup>

		<AssetGroup Name="ingamepanel_spb">
			<Type Version="0">SPB</Type>
			<Flags>
				<FSXCompatibility>false</FSXCompatibility>
			</Flags>
			<AssetDir>PackageSources\InGamePanels\</AssetDir>
			<OutputDir>.\InGamePanels\</OutputDir>
		</AssetGroup>

		<!-- WASM-Standalone-Module: liest Walker-Avatar-Position via
		     FS_OBJECT_ID_USER_CURRENT und POSTet sie an die Python-App auf
		     localhost:7801. MSFS laedt .wasm-Dateien unter /modules/
		     automatisch als Standalone-Module beim Sim-Start.
		     Format: 1:1 wie die anderen AssetGroups hier, damit fspackagetool
		     nicht stolpert. Die .wasm wird zusaetzlich im wixproj direkt ins
		     Paket-Output kopiert, falls fspackagetool den Group ueberspringt. -->
		<AssetGroup Name="wasm_bridge">
			<Type Version="0">Copy</Type>
			<Flags>
				<FSXCompatibility>false</FSXCompatibility>
			</Flags>
			<AssetDir>PackageSources\modules\</AssetDir>
			<OutputDir>.\modules\</OutputDir>
		</AssetGroup>

		<!-- EFB-App: TypeScript+SCSS-Source unter PackageSources\EfbApp\VoiceWalkerApp\,
		     gebaut via npm (esbuild) → dist/. Beim MSFS-SDK-Build wird dist/
		     1:1 kopiert nach html_ui/efb_ui/efb_apps/VoiceWalkerApp/.
		     WICHTIG: vor dem MSFS-Build muss `npm run build` im
		     EfbApp\VoiceWalkerApp\ Ordner gelaufen sein. -->
		<AssetGroup Name="efb_apps_voicewalker">
			<Type Version="0">Copy</Type>
			<Flags>
				<FSXCompatibility>false</FSXCompatibility>
			</Flags>
			<AssetDir>PackageSources\EfbApp\VoiceWalkerApp\dist\</AssetDir>
			<OutputDir>.\html_ui\efb_ui\efb_apps\VoiceWalkerApp\</OutputDir>
		</AssetGroup>
	</AssetGroups>
</AssetPackage>
