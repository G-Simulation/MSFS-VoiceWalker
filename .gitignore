# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.eggs/

# --- PyInstaller ---
build/
dist/
*.spec
*.manifest

# --- EFB-App (npm/esbuild) ---
# dist/ ist generell ignoriert (PyInstaller-Pattern oben). Aber die
# gevendorte efb_api/dist/-Lib MUSS committed werden, sonst kann die
# EFB-App nicht ohne externes SDK gebaut werden.
!msfs-project/PackageSources/EfbApp/efb_api/dist/
!msfs-project/PackageSources/EfbApp/efb_api/dist/**
msfs-project/PackageSources/EfbApp/VoiceWalkerApp/dist/
msfs-project/PackageSources/EfbApp/VoiceWalkerApp/node_modules/

# --- Runtime data (per-user, never checked in) ---
ptt_config.json
config.json
license_cache.json
port.txt
*.log
backups/

# --- IDEs ---
.vscode/
.idea/
.vs/
*.vsidx
*.user
*.suo
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Node (nur falls jemand lokal bastelt) ---
node_modules/
package-lock.json

# --- Sonstiges ---
*.bak
*.tmp
.env
.env.local
.secrets/
.mcp.json
.credentials.json

# --- Installer build output ---
installer/bin/
installer/obj/

# --- VS Upgrade logs ---
UpgradeLog*.htm

# --- Local Claude config / context ---
.claude/
CLAUDE_CONTEXT.md
.serena/

# --- Build-Time Konfiguration (wird vom Installer-Build erzeugt/ueberschrieben) ---
build_config.py

# --- MSFS SDK build intermediates ---
msfs-project/_PackageInt/
msfs-project/PackagesMetadata/
msfs-project/Packages/
MSFS/Release/*.pdb
msfs-project/Sources/wasm/MSFS/
*.tlog
*.lastbuildstate
*.recipe
*.obj
