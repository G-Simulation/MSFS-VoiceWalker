<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>{A7B3C4D5-E6F7-48A9-B0C1-D2E3F4A5B6C7}</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>main.py</StartupFile>
    <SearchPath>
    </SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>MSFSVoiceWalker</Name>
    <RootNamespace>MSFSVoiceWalker</RootNamespace>
    <LaunchProvider>Standard Python launcher</LaunchProvider>
    <InterpreterId>MSBuild|env|$(MSBuildProjectFullPath)</InterpreterId>
    <CommandLineArguments>
    </CommandLineArguments>
    <EnableNativeCodeDebugging>False</EnableNativeCodeDebugging>
    <!-- True = pythonw.exe (kein Konsolenfenster). Logs gehen ueber
         %LOCALAPPDATA%\MSFSVoiceWalker\voicewalker.log und das Browser-
         Debug-Panel (Strg+Shift+D). -->
    <IsWindowsApplication>True</IsWindowsApplication>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
    <CommandLineArguments>--debug</CommandLineArguments>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <!-- Python-Quelldateien -->
  <ItemGroup>
    <Compile Include="main.py" />
    <Compile Include="debug.py" />
    <Compile Include="ptt_backend.py" />
    <Compile Include="installer.py" />
  </ItemGroup>
  <!-- Statische Assets, Docs, Batch-Scripts, Web-UI -->
  <ItemGroup>
    <Content Include="README.md" />
    <Content Include="LICENSE" />
    <Content Include="NOTICE" />
    <Content Include="CONTRIBUTING.md" />
    <Content Include="SECURITY.md" />
    <Content Include=".gitignore" />
    <Content Include="requirements.txt" />
    <Content Include="install.bat" />
    <Content Include="start.bat" />
    <Content Include="build.bat" />
    <!-- Web-UI -->
    <Content Include="web\index.html" />
    <Content Include="web\app.js" />
    <Content Include="web\debug.js" />
    <Content Include="web\overlay.html" />
    <!-- Branding -->
    <Content Include="brand\voicewalker-logo.png" />
    <Content Include="brand\voicewalker-logo-mark.png" />
    <Content Include="brand\voicewalker-logo-mark-light.png" />
    <Content Include="brand\voicewalker-logo-horizontal.png" />
    <Content Include="packaging\build-logo-assets.py" />
    <!-- MSFS-Addon -->
    <Content Include="msfs-addon\README.md" />
    <Content Include="msfs-addon\msfsvoicewalker\manifest.json" />
    <Content Include="msfs-addon\msfsvoicewalker\layout.json" />
    <Content Include="msfs-addon\msfsvoicewalker\html_ui\Toolbar\Assets\MSFSVoiceWalker.svg" />
    <Content Include="msfs-addon\msfsvoicewalker\html_ui\InGamePanels\MSFSVoiceWalker\panel.html" />
    <Content Include="msfs-addon\msfsvoicewalker\html_ui\InGamePanels\MSFSVoiceWalker\panel.js" />
    <Content Include="msfs-addon\msfsvoicewalker\html_ui\InGamePanels\MSFSVoiceWalker\panel.css" />
  </ItemGroup>
  <!-- Ordner (damit Visual Studio sie im Solution Explorer zeigt) -->
  <ItemGroup>
    <Folder Include="web\" />
    <Folder Include="brand\" />
    <Folder Include="msfs-addon\" />
    <Folder Include="msfs-addon\msfsvoicewalker\" />
    <Folder Include="msfs-addon\msfsvoicewalker\html_ui\" />
    <Folder Include="msfs-addon\msfsvoicewalker\html_ui\Toolbar\" />
    <Folder Include="msfs-addon\msfsvoicewalker\html_ui\Toolbar\Assets\" />
    <Folder Include="msfs-addon\msfsvoicewalker\html_ui\InGamePanels\" />
    <Folder Include="msfs-addon\msfsvoicewalker\html_ui\InGamePanels\MSFSVoiceWalker\" />
  </ItemGroup>
  <ItemGroup>
    <Interpreter Include="env\">
      <Id>env</Id>
      <Version>3.13</Version>
      <Description>env (Python 3.13 (64-bit))</Description>
      <InterpreterPath>Scripts\python.exe</InterpreterPath>
      <WindowsInterpreterPath>Scripts\pythonw.exe</WindowsInterpreterPath>
      <PathEnvironmentVariable>PYTHONPATH</PathEnvironmentVariable>
      <Architecture>X64</Architecture>
    </Interpreter>
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
</Project>